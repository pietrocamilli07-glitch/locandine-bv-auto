# --- Tappe da monitorare (una o più, separate da virgola) ---
TAPPA_URLS=https://beachvolley.federvolley.it/node/XXXXX

# --- Telegram (per approvare con 1 tap) ---
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# --- Instagram / Meta (pubblicazione) ---
IG_USER_ID=1789xxxxxxxxxxx
IG_TOKEN=EAAxxxxx_long_lived_token_xxxxx

# story (default, consigliato: la grafica è 9:16) oppure feed
PUBLISH_MODE=story

# (opzionale) quali round pubblicare. Default: semifinali e finali.
# Esempi: "quarti|semifinal|finale"  oppure  ".*" per tutte le partite.
# ROUNDS_REGEX=semifinal|finale

# SITE_URL viene impostato in automatico da Netlify (variabile URL). Lascia vuoto.
# SITE_URL=
